# MongoDB Connection
# Get this from MongoDB Atlas > Connect > Drivers
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# Default User Credentials (Used for database seeding)
# Change these in .env before running seed.js in production!
ADMIN_EMAIL=admin@hopefoundation.org
ADMIN_PASSWORD=YourSecureAdminPassword123!
STAFF_EMAIL=staff@hopefoundation.org
STAFF_PASSWORD=YourSecureStaffPassword123!
MANAGER_EMAIL=manager@hopefoundation.org
MANAGER_PASSWORD=YourSecureManagerPassword123!
HR_EMAIL=hr@hopefoundation.org
HR_PASSWORD=YourSecureHRPassword123!

# Razorpay Credentials
# Get these from https://dashboard.razorpay.com/app/keys
# Use rzp_test_ prefix for testing, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL (for CORS) - Update after deploying frontend
# Examples:
# - Render: https://ooc-frontend.onrender.com
# - Netlify: https://your-site.netlify.app
# - Vercel: https://your-site.vercel.app
FRONTEND_URL=https://ooc-frontend.onrender.com
# Optional comma-separated origins, e.g. https://admin.example.org,https://app.example.org
FRONTEND_URLS=

# SMTP settings for security alert emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_FROM_EMAIL=your-email@gmail.com

# Where security alert emails are sent (single or comma-separated list)
SECURITY_ALERT_EMAIL=garglavay@gmail.com
# SECURITY_ALERT_EMAILS=garglavay@gmail.com,security-team@example.org

# Admin authentication hardening
ADMIN_MAX_FAILED_ATTEMPTS=5
ADMIN_LOCKOUT_MINUTES=30

# Port (Render will set this automatically)
PORT=3000
